# ═══════════════════════════════════════════════════════════
#  TIMELESS  —  Environment Configuration
#  Copy this file to .env and fill in your values.
#  Never commit your real .env to version control.
# ═══════════════════════════════════════════════════════════

# ── Service Ports ──────────────────────────────────────────
MANAGER_SERVICE_PORT=8082
REQUIREMENTS_SERVICE_PORT=8081
TRANSCRIPTION_SERVICE_PORT=8080
WEB_CODEGEN_SERVICE_PORT=8084

# ── LLM Provider ───────────────────────────────────────────
# Choose one: openai | openrouter | ollama
LLM_PROVIDER=openai

# OpenAI  (recommended)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_GENERAL_MODEL=gpt-4o-mini
OPENAI_ADVANCED_MODEL=o3-mini

# OpenRouter  (alternative — comment out OpenAI block above and uncomment these)
# LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=your-openrouter-api-key
# OPENROUTER_MODEL=openai/gpt-4o

# Ollama  (fully local — no API key required)
# LLM_PROVIDER=ollama
# OLLAMA_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3

# ── Transcription ──────────────────────────────────────────
# "rest"  = OpenAI Whisper API  (easiest, requires OPENAI_API_KEY)
# "local" = faster-whisper on CPU/GPU  (run bootstrap with --cpu or --gpu)
TRANSCRIPTION_METHOD=rest
TASK=transcribe
# TRANSCRIPTION_MODEL_SIZE=base   # used only when TRANSCRIPTION_METHOD=local

# ── Code Generation Agent ──────────────────────────────────
# Model used by the OpenCode agent to write and run projects
OPENCODE_MODEL=openai/gpt-4o
# OPENCODE_MODEL=anthropic/claude-sonnet-4-5
# OPENCODE_MODEL=openai/gpt-4o-mini
# Increase if large projects take longer to generate
OPENCODE_TIMEOUT_SECONDS=1800

# ── Internal Service URLs (defaults match the ports above) ─
VOICE_SERVICE_URL=http://localhost:8080/api/v0
MEETING_SERVICE_URL=http://localhost:8081/api/v0
MANAGER_SERVICE_URL=http://localhost:8082/api/v0
CODE_GENERATION_SERVICE_URL=http://localhost:8083
WEB_CODE_GENERATION_SERVICE_URL=http://localhost:8084/api/v0
WEB_CODE_GENERATION_PORT=8084
